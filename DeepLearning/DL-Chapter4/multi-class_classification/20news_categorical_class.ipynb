    "from sklearn.datasets import fetch_20newsgroups\n",
    "import string\n",
    "import numpy as np\n",
    "\n",
    "from LargeLanguageModel.Embedding.bag_of_words import bag_of_words\n",
    "\n",
    "train = fetch_20newsgroups(subset=\"train\", remove=(\"headers\", \"footers\", \"quotes\"))\n",
    "test = fetch_20newsgroups(subset=\"test\", remove=(\"headers\", \"footers\", \"quotes\"))\n",
    "\n",
    "\n",
    "def create_vocab(data):\n",
    "    vocab = {}\n",
    "    for article in data:\n",
    "        article = str(article).translate(str.maketrans(\"\", \"\", string.punctuation))\n",
    "        for i, word in enumerate(article.split()):\n",
    "            if word not in vocab.values():\n",
    "                vocab[i] = word\n",
    "\n",
    "    return vocab\n",
    "\n",
    "\n",
    "def tokenize(data):\n",
    "    vocab = create_vocab(data)\n",
    "    print(vocab)\n",
    "\n",
    "\n",
    "tokenize(train.data)\n",
    "\n",
    "\n",
    "def my_bag_of_words(sequences, num_classes):\n",
    "    results = np.zeros(shape=(len(sequences), num_classes))\n",
    "    for index, word in enumerate(sequences):\n",
    "        results[index][word] = 1.0\n",
    "    return results\n",
    "\n",
    "\n",
    "'''x_train = my_bag_of_words(train.data, )\n",
    "y_train = my_bag_of_words(train.target)\n",
    "x_test = my_bag_of_words(test.data)\n",
    "y_test = my_bag_of_words(test.target)'''\n"
